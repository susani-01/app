	# 여기에 환경 구성 명령을 작성하세요

# 앱 실행: 서버 기동 (완료 후 http://localhost:8080 에서 API 응답)
run:
	# 여기에 서버 실행 명령을 작성하세요

# 리소스 정리: 컨테이너·볼륨·임시 파일 등 실행에 사용한 모든 리소스 정리
down:
	# 여기에 정리 명령을 작성하세요
